  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mljs/kernel/issues"
  },
  "homepage": "https://github.com/mljs/kernel#readme",
  "dependencies": {
    "ml-distance-euclidean": "^3.0.1",
    "ml-kernel-gaussian": "^3.0.0",
    "ml-kernel-polynomial": "^3.0.0",
    "ml-kernel-sigmoid": "^2.0.0",
    "ml-matrix": "^6.12.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-cheminfo": "^18.0.0",
